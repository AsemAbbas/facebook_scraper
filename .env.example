# =====================================================================
# مَرصَد · ملف المتغيرات البيئية
# =====================================================================
# انسخ هذا الملف إلى .env وعدّل القيم.
# .env لن يُرفع إلى git (محمي في .gitignore).

# ----- قاعدة البيانات (MySQL / MariaDB) -----
# في cPanel: cPanel → MySQL Databases
#   1. أنشئ DB جديدة
#   2. أنشئ user جديد وأعطه صلاحيات كاملة على الـ DB
#   3. انسخ البيانات هنا

MARSAD_DB_HOST=localhost
MARSAD_DB_PORT=3306
MARSAD_DB_NAME=username_marsad
MARSAD_DB_USER=username_marsad
MARSAD_DB_PASSWORD=your_strong_password_here

# ----- إعدادات الخادم -----
HOST=127.0.0.1
PORT=5050
# NO_BROWSER=1 لمنع فتح المتصفح تلقائياً (على السيرفر)

# ----- أمان الجلسات (اختياري - يتولّد تلقائياً) -----
# SECRET_KEY=your-custom-secret-key

# ----- Telegram (اختياري) -----
# يُضبط الآن من داخل الواجهة عبر إعدادات المستخدم
